  <ProtectedClient>Enable</ProtectedClient>
  <ClipboardRedirection>Enable</ClipboardRedirection>
  <PrinterRedirection>Disable</PrinterRedirection>
  <MemoryInMB>6144</MemoryInMB>

  <MappedFolders>
