      <HostFolder>C:\Users\Emmanuel\Documents\JarvisAI</HostFolder>
      <SandboxFolder>C:\Users\WDAGUtilityAccount\Desktop\JarvisAI</SandboxFolder>
      <ReadOnly>false</ReadOnly>
