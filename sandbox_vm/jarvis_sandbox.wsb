  </MappedFolders>

  <LogonCommand>
    <Command>powershell.exe -NoExit -ExecutionPolicy Bypass -File C:\Users\WDAGUtilityAccount\Desktop\JarvisAI\sandbox_vm\setup_inside_sandbox.ps1</Command>
  </LogonCommand>
